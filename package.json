{
  "name": "swarmui-app",
  "version": "1.0.0",
  "description": "A native Electron frontend for SwarmUI — Txt2Img, Inpaint, Scheduler, Character Selector",
  "author": "das",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.swarmui.app",
    "productName": "SwarmUI App",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "src/**/*",
      "styles/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }]
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
