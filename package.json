{
  "name": "swarm-app",
  "version": "1.2.0",
  "description": "A native Electron frontend for SwarmUI — Txt2Img, Inpaint, Scheduler, Character Selector",
  "author": "das",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac":   "electron-builder --mac",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.swarmui.app",
    "productName": "Swarm-App",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "src/**/*",
      "styles/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "artifactName": "${productName}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }]
    },
    "publish": {
      "provider": "github",
      "owner": "Das-debug-a1111",
      "repo": "swarmui-app"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
